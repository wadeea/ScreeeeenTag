# OmniESL Infrastructure Config
NODE_ENV=production
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/omniesl

# Queue & Cache (Redis)
REDIS_URL=redis://localhost:6379

# IoT Communication (MQTT / Mosquitto)
MQTT_URL=mqtt://broker.omniesl.cloud:1883
MQTT_USER=cloud_admin
MQTT_PASS=secure_iot_password

# Port is fixed to 3000 by environment
PORT=3000
